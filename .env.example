# Copier ce fichier en .env et remplir les valeurs

# Clé secrète Django (générer : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=votre-cle-secrete-de-50-chars-minimum-ici

# Mode debug (False en production)
DEBUG=False

# Hôtes autorisés
ALLOWED_HOSTS=localhost,127.0.0.1,votre-app.up.railway.app

# URL PostgreSQL (injectée automatiquement par Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Domaines CSRF autorisés
CSRF_TRUSTED_ORIGINS=https://votre-app.up.railway.app

# SSL en production
SECURE_SSL_REDIRECT=True

# Scraping automatique
SCRAPE_AUTO_ENABLED=True
